{
  "suite_name": "retrieval_qa_file_grounding",
  "cases": [
    {
      "id": "mars_overview_mentions",
      "case_type": "retrieval_qa",
      "input_kind": "file",
      "input_path": "../shared/fixtures/mars_overview.md",
      "profile": "deterministic_minimal",
      "scope": "canonical",
      "top_k": 3,
      "questions": [
        {
          "id": "copilot",
          "question": "Where is Microsoft Copilot mentioned in the mars overview?",
          "expect": {
            "expected_note_paths_any": [
              "entities/microsoft-copilot.md"
            ],
            "expected_source_block_ids_any": [
              "e0004",
              "e0026"
            ],
            "expected_source_path_contains_any": [
              "mars-overview"
            ]
          }
        },
        {
          "id": "didier_altide",
          "question": "Where is Didier Altide mentioned?",
          "expect": {
            "expected_note_paths_any": [
              "entities/didier-altide.md"
            ],
            "expected_source_block_ids_any": [
              "e0003",
              "e0025"
            ],
            "expected_source_path_contains_any": [
              "mars-overview"
            ]
          }
        },
        {
          "id": "portability",
          "question": "Where is portability mentioned?",
          "expect": {
            "expected_note_paths_any": [
              "entities/portability.md"
            ],
            "expected_source_block_ids_any": [
              "e0005",
              "e0027"
            ],
            "expected_source_path_contains_any": [
              "mars-overview"
            ]
          }
        }
      ],
      "expect": {
        "outcome": "success",
        "hard_constraint_issue_count_max": 0,
        "broken_link_count_max": 0,
        "citation_coverage_min": 1.0,
        "grounded_note_rate_min": 1.0,
        "orphan_note_rate_max": 0.0,
        "qa_question_count_min": 3,
        "qa_accuracy_min": 1.0,
        "qa_note_hit_rate_min": 1.0,
        "qa_citation_hit_rate_min": 1.0
      }
    },
